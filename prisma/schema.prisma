generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}

model Car {
  id             String     @id @default(cuid())
  sourceId       String     @unique
  sourceUrl      String     @unique
  title          String
  brand          String?
  model          String?
  year           Int?
  mileageKm      Int?
  priceJpy       Int?
  totalPriceJpy  Int?
  bodyType       String?
  fuelType       String?
  transmission   String?
  drive          String?
  engineCc       Int?
  color          String?
  location       String?
  rawData        Json
  images         CarImage[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([brand])
  @@index([model])
  @@index([year])
  @@index([priceJpy])
  @@index([mileageKm])
  @@map("cars")
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, sortOrder])
  @@map("car_images")
}
